import numpy as np

class PCA:
    def __init__(self, n_components: int):
        # What it does: Decide how many principal components we want to keep
        # Why it matters: This controls the dimensionality reduction
        self.n_components = n_components
        
        # Placeholders for learned attributes
        self.mean_ = None                   # Mean of each feature
        self.components_ = None             # Principal directions
        self.explained_variance_ = None     # Variance captured by each component
        self.explained_variance_ratio_ = None  # How much info each component keeps

    def fit(self, X: np.ndarray):
        # Step 1: Calculate mean of each feature
        # Why it matters: We need to center the data before PCA
        self.mean_ = np.mean(X, axis=0)
        X_centered = X - self.mean_

        # Step 2: Build covariance matrix
        # Why it matters: Covariance shows how features vary together
        cov_matrix = np.cov(X_centered, rowvar=False)

        # Step 3: Eigen decomposition
        # What it does: Find directions (eigenvectors) and their importance (eigenvalues)
        eigenvalues, eigenvectors = np.linalg.eigh(cov_matrix)

        # Step 4: Sort eigenvalues descending
        # Why it matters: Largest eigenvalues = most important directions
        sorted_idx = np.argsort(eigenvalues)[::-1]
        eigenvalues = eigenvalues[sorted_idx]
        eigenvectors = eigenvectors[:, sorted_idx]

        # Step 5: Keep only top n_components
        self.components_ = eigenvectors[:, :self.n_components]
        self.explained_variance_ = eigenvalues[:self.n_components]

        # Step 6: Calculate explained variance ratio
        # What it shows: How much information each component keeps
        total_var = np.sum(eigenvalues)
        self.explained_variance_ratio_ = self.explained_variance_ / total_var

    def transform(self, X: np.ndarray):
        # Center the data using the mean we learned
        X_centered = X - self.mean_
        # Project data onto principal components
        # Why it matters: Reduces dimensionality while keeping most info
        return np.dot(X_centered, self.components_)

    def fit_transform(self, X: np.ndarray):
        # Shortcut: first fit the PCA, then transform the data
        self.fit(X)
        return self.transform(X)

    def inverse_transform(self, X_reduced: np.ndarray):
        # Reconstruct original data from reduced components
        # Why it matters: Lets you see approx of original data
        return np.dot(X_reduced, self.components_.T) + self.mean_


# ───────────────────────────────────────────────
# Test block: check that PCA works as expected
# ───────────────────────────────────────────────
if __name__ == "__main__":
    # Create random dataset: 100 samples, 10 features
    X = np.random.rand(100, 10)

    # Keep top 3 principal components
    pca = PCA(n_components=3)
    X_reduced = pca.fit_transform(X)

    print("Original shape:", X.shape)
    print("Reduced shape:", X_reduced.shape)
    print("Explained variance ratio:", pca.explained_variance_ratio_)

